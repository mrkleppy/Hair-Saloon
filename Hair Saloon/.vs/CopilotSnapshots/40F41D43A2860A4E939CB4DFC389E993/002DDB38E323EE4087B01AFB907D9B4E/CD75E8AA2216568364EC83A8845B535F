// Member side Appointment Management Module

void appointmentManager() {
    char selection;
    clearScreen();

    do {
        cout << "Reminder: 50% would be charged in case of cancelled appointments." << endl;
        cout << "1. Book an Appointment" << endl;
        cout << "2. Remove an Appointment" << endl;
        cout << "0. Exit" << endl;
        cout << "Selection: ";

        cin >> selection;
        cin.ignore();

        switch(selection) {
        case '1':
            clearScreen();
            bookAppointment();
            break;

        case '2':
            clearScreen();
            removeAppointment();
            break;

        case '0':
            clearScreen();
            return;

        default:
            clearScreen();
            cout << "Invalid input! Please enter 0, 1, or 2!" << endl;

        }

    } while(true);
}

// Book appointment

void bookAppointment() {
    char selection, gender, confirmation;
    int persons;
    string date, timeSlot;
    double total = 0;
    clearScreen();

    do {
        cout << "Enter 'q' to quit." << endl;
        cout << "Enter date to book appointment (DD/MM/YYYY): ";
        getline(cin, date);

        if (date == "q") {
            clearScreen();
            return;
        }
        // validation

        cout << "\nPlease book within a slot of 9am to 5pm." << endl <<
            "Please enter 00 or 30 for minutes and in 24 - Hours format(23:30)" << endl;
        cout << "Enter time slot (HH:MM): ";
        getline(cin, timeSlot);

        if (timeSlot == "q") {
            clearScreen();
            return;

        }
        // validation
        break;

    } while(true);

    do {
        cout << "Choose Service Type:\t\t(M)ale\t\t(F)emale" <<
            "\n1. Hair Cut\t\t\tRM 25.00\t\tRM45.00" <<
            "\n2. Hair Coloring\t\tRM 80.00\t\tRM170.00" <<
            "\n3. Hair Treatment\t\tRM 70.00\t\tRM90.00" <<
            "\n4. Hair Styling\t\t\tRM 30.00\t\tRM35.00" << 
            "\nEnter 'c' to complete your appointments!" << endl;

        cout << "Selection: ";
        cin >> selection;
        cin.ignore();

        // validations and c to complete transaction
        total = 1;

        switch (selection) {
        case '1':
            break;

        case '2':
            break;

        case '3':
            break;

        case '4':
            break;

        case 'c':
            clearScreen();
            return;

        default:
            clearScreen();
            cout << "Invalid input. Please enter 1, 2, 3, 4, or c to complete transaction!\n";
            continue;

        }

        cout << "Gender: ";
        cin >> gender;
        cin.ignore();

        // validation for m and f

        cout << "Person(s) (Not more than 5): ";
        cin >> persons;
        cin.ignore();

        // try catch

        cout << "Confirm adding " << selection << " (" << gender << ") for " << persons << "person(s)?" <<
            "\n(Y/N): ";
        cin >> confirmation;
        cin.ignore();

        // validations

        // calculate the total amount of appointment
        completeTransaction(total);
        break;

    } while(true);
}

void completeTransaction(double total) {
    char option;
    int memberPointsAdded = 0, memberPoints = 0;
    clearScreen();

    do {
        cout << "Total will be RM" << fixed << setprecision(2) << total << endl;
        cout << "Continue? (Y/N): ";
        cin >> option;

		if (option == 'Y' || option == 'y') {
			// add to the appointment list

			memberPointsAdded = total / 10; // RM 10 = 1 point
			memberPoints += memberPointsAdded;
			break;

		}
		else if (option == 'N' || option == 'n') {
			return;

		}
		else {
			clearScreen();
			cout << "Invalid input! Please enter Y or N!" << endl;

		}
    } while(true);

    // Add to the user's member points

    clearScreen();
    cout << "Payment Done!" <<
        "\nAppointment Request Added!" <<
        "\n" << memberPointsAdded << " points has been creditted to your account!" <<
        "\nCurrent Member Points: " << memberPoints <<
        "\nPress enter to continue...";

	cin.get(); // Wait for user to press enter
    cin.ignore(); // Wait for user to press enter

    clearScreen();

}

