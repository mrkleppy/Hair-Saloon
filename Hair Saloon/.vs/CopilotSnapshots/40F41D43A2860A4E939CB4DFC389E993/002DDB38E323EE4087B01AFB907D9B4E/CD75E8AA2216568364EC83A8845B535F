        cout << "\n(n = next page, p = previous page, q = quit" << endl <<
            "Enter Appointment No. to manage status: ";

        getline(cin, appointmentNo);

		if (appointmentNo == "q" || appointmentNo == "Q") {
			clearScreen();
			return;

		}

        break;

    } while(true);

    clearScreen();
    appointmentStatusManagement(appointmentNo, username);
}

void appointmentStatusManagement(string appointmentNo, string username) {
	char selection;
    clearScreen();

	do {
		cout << "Appointment No. " << appointmentNo << " is being managed by " << username << endl; // Display all of the staffs that manages this appointment
        cout << "Update Appointment Status:" << endl;
        cout << "1. Mark as Completed" << endl;
		cout << "2. Cancel Appointment" << endl;
		cout << "0. Exit" << endl;
		cout << "Selection: ";
		
        cin >> selection;
		cin.ignore();
		
        switch (selection) {
		case '1':
			clearScreen();

            do {
                cout << "Appointment No. " << appointmentNo << " is done?" << endl <<
                    "Confirm (Y/N): ";
                char confirmation;
                cin >> confirmation;
                cin.ignore();

				if (confirmation == 'Y' || confirmation == 'y') {
					// mark as completed

                    clearScreen();
					cout << "Appointment No. " << appointmentNo << " has been marked as completed!" << endl;

					break;

				}
				else if (confirmation == 'N' || confirmation == 'n') {
					clearScreen();
					return;

				}
				else {
					clearScreen();
					cout << "Invalid input! Please enter Y or N!" << endl;

				}

            } while(true);

			break;

		case '2':
			clearScreen();
			
            do {
                cout << "Why is " << appointmentNo << " being cancelled?" << endl <<
                    "Reason: ";

                char reason[50];
                cin >> reason;

                cout << "\nAppointment No. " << appointmentNo << " is being cancelled for the following reason: " << endl <<
                    reason << endl <<
                    "Confirm (Y/N): ";

                char confirmation;
                cin >> confirmation;
                cin.ignore();

				if (confirmation == 'Y' || confirmation == 'y') {
					// cancel appointment

                    clearScreen();
					cout << "Appointment No. " << appointmentNo << " has been cancelled!" << endl;

					break;

				}
				else if (confirmation == 'N' || confirmation == 'n') {
					clearScreen();

                    return;
				}
				else {
					clearScreen();
					cout << "Invalid input! Please enter Y or N!" << endl;

				}

                break;
            } while(true);

            break;

		case '0':
			clearScreen();
			return;

		default:
			clearScreen();
			cout << "Invalid input! Please enter 0, 1, or 2!" << endl;

		}

        break;

	} while (true);
}

