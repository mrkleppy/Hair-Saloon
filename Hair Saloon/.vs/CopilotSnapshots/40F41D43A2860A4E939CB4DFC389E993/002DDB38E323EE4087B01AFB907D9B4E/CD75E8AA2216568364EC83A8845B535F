	string date, timeSlot; // date and time of the appointment.

	do {
		cout << "Assigning Appointment No. " << appointmentNo <<
            "\t\t(" << staffCount << " staff needed!)" << endl <<
            "Date: " << date << "\t\t" << "Time: " << timeSlot << endl <<
            "Services: ";

        // for loop here to show each services that is booked for this appointment

        cout << "Staff List: " << endl;

		// for loop here to show each staff that is available for this appointment

		// for loop here to assign each staff to this appointment, based on the number of staff needed for this appointment
        cout << "Assign staff 1: "; // placeholder
        
        string staffID;
        getline(cin, staffID);

		if (staffID == "q" || staffID == "Q") {
			clearScreen();
			return;

		}

        while(true) {
            cout << "Confirm assigning staff ";

            // for loop here to show each staff that is assigned to this appointment

            cout << "to Appointment No. " << appointmentNo << "?" << endl <<
                "Choice (Y/N): ";

            char confirmation;
